# xeus-brainfuck cmake module
# This module sets the following variables in your project::
#
#   xeus-brainfuck_FOUND - true if xeus-brainfuck was found on the system
#   xeus-brainfuck_INCLUDE_DIRS - the directory containing xeus-brainfuck headers
#   xeus-brainfuck_LIBRARY - the library for dynamic linking
#   xeus-brainfuck_STATIC_LIBRARY - the library for static linking

@PACKAGE_INIT@

set(CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR};${CMAKE_MODULE_PATH}")

@XEUS_BRAINFUCK_CONFIG_CODE@

include(CMakeFindDependencyMacro)
find_dependency(xeus-zmq @xeus-zmq_REQUIRED_VERSION@)
find_dependency(cppzmq @cppzmq_REQUIRED_VERSION@)


if (NOT TARGET xeus-brainfuck AND NOT TARGET xeus-brainfuck-static)
    include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

    if (TARGET xeus-brainfuck AND TARGET xeus-brainfuck-static)
        get_target_property(@PROJECT_NAME@_INCLUDE_DIR xeus-brainfuck INTERFACE_INCLUDE_DIRECTORIES)
        get_target_property(@PROJECT_NAME@_LIBRARY xeus-brainfuck LOCATION)
        get_target_property(@PROJECT_NAME@_STATIC_LIBRARY xeus-brainfuck-static LOCATION)
    elseif (TARGET xeus-brainfuck)
        get_target_property(@PROJECT_NAME@_INCLUDE_DIR xeus-brainfuck INTERFACE_INCLUDE_DIRECTORIES)
        get_target_property(@PROJECT_NAME@_LIBRARY xeus-brainfuck LOCATION)
    elseif (TARGET xeus-brainfuck-static)
        get_target_property(@PROJECT_NAME@_INCLUDE_DIR xeus-brainfuck-static INTERFACE_INCLUDE_DIRECTORIES)
        get_target_property(@PROJECT_NAME@_STATIC_LIBRARY xeus-brainfuck-static LOCATION)
        set(@PROJECT_NAME@_LIBRARY ${@PROJECT_NAME@_STATIC_LIBRARY})
    endif ()
endif ()
